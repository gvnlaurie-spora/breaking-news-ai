# Logging
LOG_LEVEL=info

# Content
MAX_CLIPS=8
SEGMENT_DURATION=180
INTRO_DURATION=5

# Output
OUTPUT_DIR=./output

# Video
VIDEO_W=1280
VIDEO_H=720
VIDEO_FPS=24
AUDIO_BITRATE=128k
FFMPEG_PRESET=fast
FFMPEG_CRF=23

# Network
DOWNLOAD_CONCURRENCY=3
EXEC_TIMEOUT_MS=300000
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
MIN_DISK_SPACE_GB=2

# TTS (Azure is optional — edge-tts used if not set)
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus
AZURE_VOICE=en-US-JennyNeural
EDGE_TTS_VOICE=en-US-JennyNeural

# Flags
DRY_RUN=false
CLEANUP_BEFORE=false
