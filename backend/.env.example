# ── DATABASE ──────────────────────────────────────────────────
# SQLite (local dev)
DATABASE_URL="file:./dev.db"
# PostgreSQL (production)
# DATABASE_URL="postgresql://user:password@localhost:5432/breaking_news?schema=public"

# ── SERVER ────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# ── AI ────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# ── AZURE SPEECH (TTS) ────────────────────────────────────────
# Format: https://your-region.api.cognitive.microsoft.com/
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_ENDPOINT=https://eastus.api.cognitive.microsoft.com/

# ── MEDIA APIs (optional but recommended) ─────────────────────
# Free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Free key at https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# Pollinations.ai — NO KEY NEEDED (AI image generation)

# Internet Archive — NO KEY NEEDED (news footage scraping)

# ── YOUTUBE ───────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth-callback
YOUTUBE_REFRESH_TOKEN=your_refresh_token
# Run this to get your refresh token:
# npx tsx src/scripts/getRefreshToken.ts
