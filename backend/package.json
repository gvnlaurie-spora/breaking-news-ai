{
  "name": "backend",
  "version": "2.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 tsx watch src/server.ts",
    "scrape": "tsx src/scripts/scrape.ts",
    "process-articles": "tsx src/scripts/processArticles.ts",
    "generate-videos": "NODE_OPTIONS=--dns-result-order=ipv4first tsx src/scripts/generate-videos.ts",
    "upload-videos": "tsx src/scripts/uploadVideos.ts",
    "build": "tsc --skipLibCheck",
    "start": "node dist/server-cron.js",
    "prisma:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "auto": "tsx src/scripts/auto-pipeline.ts",
    "auto:once": "tsx src/scripts/auto-pipeline.ts --once",
    "pipeline:dry": "tsx src/scripts/auto-pipeline.ts --dry-run",
    "pipeline:scrape-only": "npm run scrape && npm run process-articles",
    "full-run": "npm run scrape && npm run process-articles && npm run generate-videos && npm run upload-videos",
    "build-news": "tsx src/scripts/build-news-show.ts",
    "build-news:dry": "DRY_RUN=1 tsx src/scripts/build-news-show.ts",
    "build-news:debug": "LOG_LEVEL=debug tsx src/scripts/build-news-show.ts",
    "build-news:clean": "CLEANUP_BEFORE=1 tsx src/scripts/build-news-show.ts",
    "show:morning": "tsx src/scripts/build-news-show.ts --show=morning",
    "show:noon": "tsx src/scripts/build-news-show.ts --show=noon",
    "show:evening": "tsx src/scripts/build-news-show.ts --show=evening",
    "show:night": "tsx src/scripts/build-news-show.ts --show=night",
    "start:dev": "tsx src/server-cron.ts",
    "build-news-runner": "tsx src/scripts/build-news-runner.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Breaking News AI — 30-minute compiled news video pipeline",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@mistralai/mistralai": "^1.0.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.1",
    "bullmq": "^5.1.0",
    "canvas": "^3.2.3",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "fastify": "^5.8.5",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^173.0.0",
    "ioredis": "^5.3.2",
    "microsoft-cognitiveservices-speech-sdk": "^1.13.1",
    "node-cron": "^4.2.1",
    "node-webvtt": "^1.0.0",
    "ollama": "^0.6.3",
    "prisma": "^5.7.0",
    "rss-parser": "^3.12.0",
    "sqlite3": "^6.0.1",
    "tsx": "^4.22.4"
  },
  "engines": {
    "node": ">=20.0.0 <22.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.9.2",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.0.2",
    "typescript": "^6.0.3"
  }
}
